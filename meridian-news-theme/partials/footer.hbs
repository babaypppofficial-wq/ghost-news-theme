<footer class="site-footer">
    <div class="container">
        <!-- Footer Main Content -->
        <div class="footer-grid">
            <div class="footer-section">
                <h3 class="footer-title">{{@site.title}}</h3>
                <p class="footer-description">{{@site.description}}</p>
                <div class="social-links">
                    {{#if @site.facebook}}
                        <a href="https://facebook.com/{{@site.facebook}}" class="social-icon" title="Facebook">f</a>
                    {{/if}}
                    {{#if @site.twitter}}
                        <a href="https://twitter.com/{{@site.twitter}}" class="social-icon" title="Twitter">𝕏</a>
                    {{/if}}
                    {{#if @site.instagram}}
                        <a href="https://instagram.com/{{@site.instagram}}" class="social-icon" title="Instagram">📷</a>
                    {{/if}}
                </div>
            </div>

            <div class="footer-section">
                <h4 class="footer-subtitle">Categories</h4>
                <ul class="footer-links">
                    {{#foreach tags limit="6"}}
                        <li><a href="{{url}}">{{name}}</a></li>
                    {{/foreach}}
                </ul>
            </div>

            <div class="footer-section">
                <h4 class="footer-subtitle">Navigation</h4>
                <ul class="footer-links">
                    {{#foreach navigation}}
                        <li><a href="{{url}}">{{label}}</a></li>
                    {{/foreach}}
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Contact</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h4 class="footer-subtitle">Newsletter</h4>
                <p>Subscribe for the latest news and updates.</p>
                <form class="footer-newsletter">
                    <input type="email" placeholder="Your email" required />
                    <button type="submit" class="btn-subscribe-small">Subscribe</button>
                </form>
            </div>
        </div>

        <!-- Footer Bottom -->
        <div class="footer-bottom">
            <p class="copyright">&copy; {{date format="YYYY"}} {{@site.title}}. All rights reserved.</p>
            <ul class="footer-meta-links">
                <li><a href="#">Privacy Policy</a></li>
                <li><a href="#">Terms of Service</a></li>
                <li><a href="#">Sitemap</a></li>
            </ul>
        </div>
    </div>
</footer>
