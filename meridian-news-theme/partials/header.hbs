<header class="site-header">
    <nav class="navbar">
        <div class="container navbar-container">
            <!-- Logo -->
            <div class="logo-section">
                {{#if @site.logo}}
                    <a href="{{@site.url}}" class="logo-link">
                        <img src="{{@site.logo}}" alt="{{@site.title}}" class="logo" />
                    </a>
                {{else}}
                    <a href="{{@site.url}}" class="site-title-link">{{@site.title}}</a>
                {{/if}}
            </div>

            <!-- Navigation Menu -->
            <div class="nav-menu">
                <ul class="nav-list">
                    <li><a href="{{@site.url}}" class="nav-link">Home</a></li>
                    {{#foreach navigation}}
                        <li><a href="{{url}}" class="nav-link {{#if active}}active{{/if}}">{{label}}</a></li>
                    {{/foreach}}
                </ul>
            </div>

            <!-- Right Section -->
            <div class="nav-actions">
                <button class="search-btn" aria-label="Search">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                </button>
                {{#if @member}}
                    <a href="#" class="btn-account">Account</a>
                {{else}}
                    <a href="#" class="btn-subscribe">Subscribe</a>
                {{/if}}
            </div>
        </div>
    </nav>

    <!-- Search Modal -->
    <div class="search-modal" style="display:none;">
        <div class="search-overlay"></div>
        <div class="search-box">
            <input type="text" class="search-input" placeholder="Search articles..." />
            <div class="search-results"></div>
        </div>
    </div>
</header>
