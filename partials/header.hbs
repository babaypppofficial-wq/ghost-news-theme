<header class="site-header">
    <nav class="navbar">
        <div class="container navbar-container">
            <div class="logo-section">
                {{#if @site.logo}}
                    <a href="{{@site.url}}" class="logo-link">
                        <img src="{{@site.logo}}" alt="{{@site.title}}" class="logo" />
                    </a>
                {{else}}
                    <a href="{{@site.url}}" class="site-title-link">{{@site.title}}</a>
                {{/if}}
            </div>

            <div class="nav-menu">
                <ul class="nav-list">
                    <li><a href="{{@site.url}}" class="nav-link">Home</a></li>
                    {{#foreach navigation}}
                        <li><a href="{{url}}" class="nav-link {{#if active}}active{{/if}}">{{label}}</a></li>
                    {{/foreach}}
                </ul>
            </div>

            <div class="nav-actions">
                <button class="search-toggle" aria-label="Search">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                </button>
                {{#if @member}}
                    <a href="#" class="btn btn-secondary">Account</a>
                {{else}}
                    <a href="#" class="btn btn-primary">Subscribe</a>
                {{/if}}
            </div>
        </div>
    </nav>
</header>

<div class="search-modal" style="display:none;">
    <div class="search-overlay"></div>
    <div class="search-box">
        <input type="text" placeholder="Search articles..." class="search-input" />
        <div class="search-results"></div>
    </div>
</div>
